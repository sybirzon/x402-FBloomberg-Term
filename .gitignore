# ── Dependencies ─────────────────────────────────────────────────────────────
**/node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
**/dist/

# ── Environment files (contain private keys, API keys) ───────────────────────
**/.env
**/.env.*
!**/.env.example

# ── Fireblocks credentials ────────────────────────────────────────────────────
**/secrets/
**/*.pem
**/*.key

# ── Facilitator config (written at setup time — contains Fireblocks API key) ──
x402-facilitator/config/facilitator.json

# ── OSS facilitator clone (re-cloned by setup-fbloomberg.sh on every fresh setup) ──
# Don't ship the cloned source as part of this repo — keep the canonical source
# upstream at github.com/fireblocks/x402-facilitator.
/x402-facilitator/

# ── Database files ────────────────────────────────────────────────────────────
**/data/
**/*.db
**/*.db-shm
**/*.db-wal

# ── Logs ─────────────────────────────────────────────────────────────────────
**/*.log

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
.history/

# ── Personal runbooks (contain workspace-specific UUIDs / addresses) ──────────
bloombergterminal_x402_demo.md
*.local.md

# ── MCP config — generated from .mcp.json.template by setup-fbloomberg.sh ──────
# Contains machine-specific absolute paths. The committable source is .mcp.json.template.
.mcp.json
