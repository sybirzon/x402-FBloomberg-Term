# Required: EOA private key (generate with: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)")
PRIVATE_KEY=

# Merchant endpoint to test against (default: http://localhost:3010/premium)
MERCHANT_URL=http://localhost:3010/premium

# Optional: force a specific chain (84532 = Base Sepolia, 11155111 = Ethereum Sepolia)
# CHAIN=84532

# Optional: force a specific mechanism (eip3009 | permit2 | erc7710)
# MECHANISM=eip3009

# Optional: auto-submit on-chain approve(Permit2, MAX) if allowance is missing (requires gas ETH)
# AUTO_APPROVE=true

# Optional: verify the facilitator's X-402-Integrity envelope before signing
# VERIFY_INTEGRITY=true
# REQUIRE_INTEGRITY=true

# Optional: RPC URL overrides
# RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
# RPC_URL_ETH_SEPOLIA=https://ethereum-sepolia-rpc.publicnode.com
