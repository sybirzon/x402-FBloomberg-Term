{
  "name": "x402-test-client",
  "version": "1.0.0",
  "private": true,
  "description": "Lightweight x402 test client — signs EIP-3009, Permit2, and ERC-7710 (via EIP-7702 self-upgrade). No Fireblocks required.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "echo -ne \"\\033]0;Agent\\007\" && ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "whoami": "ts-node src/whoami.ts",
    "mcp-server": "tsx src/mcp-server.mts"
  },
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "canonicalize": "^2.1.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
