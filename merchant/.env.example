PORT=3010
FACILITATOR_URL=http://localhost:3001
NODE_ENV=development

# Required: mint with `x402 keys create --scopes process-payments --label merchant`
FACILITATOR_API_KEY=

# Required: returned by `x402 products add --name Premium --endpoint /premium --asset <ASSET> --price 100000`
PREMIUM_PRODUCT_ID=

# optimistic | settle-first
SETTLEMENT_MODE=optimistic
